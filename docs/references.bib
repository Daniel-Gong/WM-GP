@article{schneegansStochasticSamplingProvides2020,
  title = {Stochastic Sampling Provides a Unifying Account of Visual Working Memory Limits},
  author = {Schneegans, Sebastian and Taylor, Robert and Bays, Paul M.},
  year = 2020,

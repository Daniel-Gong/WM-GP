\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Inter-item repulsion bias.} \textbf  {(A)} Repulsion bias (negative = away from distractor) as a function of target--distractor color distance, showing the characteristic inverted-U pattern. \textbf  {(B)} Encoding time $\times $ color distance interaction: shorter encoding (fewer epochs) produces stronger bias at small--medium distances, replicating the pattern reported by Chunharas et al.\ (2022). Shaded regions: $\pm 1$ SEM.}}{12}{figure.caption.9}\protected@file@percent }
\newlabel{fig:bias}{{4}{12}{\textbf {Inter-item repulsion bias.} \textbf {(A)} Repulsion bias (negative = away from distractor) as a function of target--distractor color distance, showing the characteristic inverted-U pattern. \textbf {(B)} Encoding time $\times $ color distance interaction: shorter encoding (fewer epochs) produces stronger bias at small--medium distances, replicating the pattern reported by Chunharas et al.\ (2022). Shaded regions: $\pm 1$ SEM}{figure.caption.9}{}}

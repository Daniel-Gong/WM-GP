\@writefile{lot}{\contentsline {table}{\numberline {S2}{\ignorespaces \textbf  {Information-theoretic model comparison.} AIC, BIC, and AICc for four benchmark models fit by MLE to $n = 1{,}300$ pooled MemGP simulation errors (100 trials $\times $ set sizes 1, 2, 4, 6). $\Delta $AIC and $\Delta $BIC are differences from the best-fitting model (VP). By conventional guidelines ($\Delta > 10$ indicates essentially no support; Burnham \& Anderson, 2002), VP is decisively preferred.}}{17}{table.caption.21}\protected@file@percent }
\newlabel{tab:ic}{{S2}{17}{\textbf {Information-theoretic model comparison.} AIC, BIC, and AICc for four benchmark models fit by MLE to $n = 1{,}300$ pooled MemGP simulation errors (100 trials $\times $ set sizes 1, 2, 4, 6). $\Delta $AIC and $\Delta $BIC are differences from the best-fitting model (VP). By conventional guidelines ($\Delta > 10$ indicates essentially no support; Burnham \& Anderson, 2002), VP is decisively preferred}{table.caption.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S1}{\ignorespaces \textbf  {Parameter sensitivity analysis.} Mean absolute error vs.\ set size under systematic variation of three key model parameters. \textbf  {(A)}~Inducing grid size $m \in \{6, 10, 16\}$ ($M = m^2$ inducing points): larger grids reduce error at all set sizes, but the monotonic set-size gradient is preserved. \textbf  {(B)}~KL weight $\beta \in \{0.1, 1, 5\}$: higher $\beta $ accelerates forgetting and increases error, while the qualitative set-size pattern remains stable. \textbf  {(C)}~Kernel lengthscale $\lambda \in \{5, 10, 20\}$: shorter lengthscales yield sharper item peaks and lower error for small $N$, but all values produce increasing error with set size.}}{18}{figure.caption.23}\protected@file@percent }
\newlabel{fig:param_sensitivity}{{S1}{18}{\textbf {Parameter sensitivity analysis.} Mean absolute error vs.\ set size under systematic variation of three key model parameters. \textbf {(A)}~Inducing grid size $m \in \{6, 10, 16\}$ ($M = m^2$ inducing points): larger grids reduce error at all set sizes, but the monotonic set-size gradient is preserved. \textbf {(B)}~KL weight $\beta \in \{0.1, 1, 5\}$: higher $\beta $ accelerates forgetting and increases error, while the qualitative set-size pattern remains stable. \textbf {(C)}~Kernel lengthscale $\lambda \in \{5, 10, 20\}$: shorter lengthscales yield sharper item peaks and lower error for small $N$, but all values produce increasing error with set size}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S2}{\ignorespaces \textbf  {Comparison with human data.} MemGP mixture statistics ($w$, CSD) overlaid with approximate human data from Van den Berg et al.\ (2012). The model's emergent error profile falls within the empirical range.}}{19}{figure.caption.24}\protected@file@percent }
\newlabel{fig:human_overlay}{{S2}{19}{\textbf {Comparison with human data.} MemGP mixture statistics ($w$, CSD) overlaid with approximate human data from Van den Berg et al.\ (2012). The model's emergent error profile falls within the empirical range}{figure.caption.24}{}}
